#!/bin/bash
if [[ ! -v ZELLIJ ]]; then
    printf 'ide: run inside zellij\n' >&2
    exit 1
fi

layout="${XDG_CONFIG_HOME:-$HOME/.config}/zellij/layouts/ide.kdl"
if [[ ! -f "$layout" ]]; then
    printf 'ide: %s missing — run home-manager switch\n' "$layout" >&2
    exit 1
fi

zellij action override-layout "$layout" \
    --apply-only-to-active-tab
